# Application
APP_NAME=rag-api
APP_ENV=development
LOG_LEVEL=INFO

# PostgreSQL + pgvector
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragdb

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_QUERY=3600
REDIS_TTL_EMBEDDING=86400

# Embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024

# Chunking defaults
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# File upload
MAX_FILE_SIZE_MB=50
